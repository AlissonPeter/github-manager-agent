# Token de Acesso Pessoal do GitHub (escopo repo)
GITHUB_TOKEN=seu_github_token_aqui

# Token do Bot do Telegram obtido com @BotFather
TELEGRAM_TOKEN=seu_telegram_token_aqui

# Chat ID do Telegram para receber notificações do bot
TELEGRAM_CHAT_ID=seu_telegram_chat_id_aqui

# Chave de API do Google Gemini para o motor do LangGraph
GEMINI_API_KEY=sua_gemini_api_key_aqui

# Porta do servidor backend (por padrão é 8080)
BACKEND_HOST_PORT=8080
